# .env.example

# This file is used to document the environment variables used in the project.
# It is not used in the application directly, but serves as a reference for developers.

# Example environment variables for the todoy app
# These variables are not used in the application, as it relies on LocalStorage for data persistence.
# However, they are included here for completeness and to demonstrate how environment variables
# might be used in a more complex application.

# API_BASE_URL=https://api.example.com
# API_KEY=your_api_key_here